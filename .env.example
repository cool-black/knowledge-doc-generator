# LLM API Keys
# Moonshot (Kimi) - 当前默认使用
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# 搜索 API (可选，用于网页搜索)
SERPER_API_KEY=your_serper_api_key
